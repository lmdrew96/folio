# --- Convex ---
# Both of these are written automatically the first time you run `npx convex dev`.
# (CONVEX_DEPLOYMENT is local-only; NEXT_PUBLIC_CONVEX_URL is what the browser talks to.)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk ---
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# NOTE: CLERK_JWT_ISSUER_DOMAIN is NOT set here.
# It goes on the Convex dashboard (Settings → Environment Variables), because
# auth.config.ts runs on the Convex backend. It's the "Issuer" of the Clerk
# JWT template you create named exactly "convex".
