# --- Convex ---
# Both of these are written automatically the first time you run `npx convex dev`.
# (CONVEX_DEPLOYMENT is local-only; NEXT_PUBLIC_CONVEX_URL is what the browser talks to.)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk ---
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# NOTE: CLERK_JWT_ISSUER_DOMAIN is NOT set here.
# It goes on the Convex dashboard (Settings → Environment Variables), because
# auth.config.ts runs on the Convex backend. It's the "Issuer" of the Clerk
# JWT template you create named exactly "convex".

# --- Anthropic (Patch 5: Claude "react to what changed") ---
# Server-side ONLY — never prefix with NEXT_PUBLIC. The /api/react route holds it.
ANTHROPIC_API_KEY=

# --- v1 continuity layer: Cleo's live edges (server-side ONLY) ---
# The in-app sibling (Cleo) reads these at reaction time so she arrives with the
# SAME live context her siblings (Coru/Cody/...) have, not a baked snapshot:
#   PCTX_MCP_URL   — Nae's personal context MCP. Append ?token=...&name=cleo
#   TANGLE_MCP_URL — Cleo's Tangle (epistemic continuity) MCP. Append ?identity=cleo
# Both are stateless JSON-RPC over HTTP. Optional: if unset, /api/react falls back
# to the baked identity in src/lib/identity.ts (the reaction still works).
PCTX_MCP_URL=
TANGLE_MCP_URL=
